<theme>
    <!-- colors -->

    <!-- ///  ZUNE HD - ORANGE ACCENT  /// -->
    <!-- Inspired by the Zune HD software UI: deep charcoal/black backgrounds,        -->
    <!-- white typography, and a vivid orange accent (#F2740D).                        -->
    <!-- Design language: Metro / Swiss minimalism, content-first, no chrome.          -->
    <colorScheme name="zune-hd-orange">
        <variables>
            <!-- System View -->
            <logoSource>./_inc/systems/logos</logoSource>
            <artworkSource>./_inc/systems/artwork-screenshots</artworkSource>
            <systemViewLogoPos>0.5 0.5</systemViewLogoPos>
            <systemBackgroundColor>111111</systemBackgroundColor>
            <systemArtSaturation>0.5</systemArtSaturation>
            <systemArtColor>ffffff99</systemArtColor>
            <systemLogoColor>F2740D</systemLogoColor>

            <!-- Gamelist View - List Variants -->
            <gamelistListBackgroundColor>1C1C1C</gamelistListBackgroundColor>
            <gamelistListLogoColor>F2740D</gamelistListLogoColor>
            <gamelistListTextlistBackgroundColor>111111</gamelistListTextlistBackgroundColor>
            <gamelistListTextlistSelectedColor>111111</gamelistListTextlistSelectedColor>
            <gamelistListTextlistSelectedBackgroundColor>F2740D</gamelistListTextlistSelectedBackgroundColor>
            <gamelistListTextlistUnselectedColor>ffffff66</gamelistListTextlistUnselectedColor>
            <gamelistListMetadataColor>ffffffaa</gamelistListMetadataColor>
            <gamelistListMetadataIconColor>F2740D99</gamelistListMetadataIconColor>
            <gamelistListRatingColor>F2740Dcc</gamelistListRatingColor>
            <gamelistListDescriptionColor>ffffffdd</gamelistListDescriptionColor>

            <!-- Help System -->
            <helpBackgroundColor>111111ee</helpBackgroundColor>
            <helpIconColor>F2740D</helpIconColor>
            <helpTextColor>ffffff88</helpTextColor>

            <!-- System Status (clock, battery, etc.) -->
            <statusColor>ffffff</statusColor>
            <statusBackgroundColor>111111ee</statusBackgroundColor>
        </variables>
    </colorScheme>

