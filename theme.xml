<!-- theme name: Zune HD (ES-DE Edition) author: lunardaddy69 based on Art Book Next by Anthony Caccese license: creative commons CC-BY-NC-SA https://github.com/anthonycaccese/art-book-next-es-de -->
<theme>

    <!-- /// System Metadata /// -->
    <include>./_inc/systems/_metadata-global/_default.xml</include>
    <include>./_inc/systems/_metadata-global/${system.theme}.xml</include>

    <!-- /// Variables /// -->
    <variables>
        <fontLight>./_inc/fonts/Nunito-Italic-VariableFont_wght.ttf</fontLight>
        <fontRegular>./_inc/fonts/Nunito-VariableFont_wght.ttf</fontRegular>
        <fontLogo>./_inc/fonts/ChangaOne-Italic.ttf</fontLogo>
        <spacerImage>./_inc/images/space.png</spacerImage>
    </variables>

    <include>./colors.xml</include>

    <!-- /// All Views /// -->
    <view name="system,gamelist">

        <!-- Start: menu styling resets -->
        <helpsystem name="help-menu-view">
            <scope>menu</scope>
            <origin>0.5 1</origin>
            <pos>0.5 0.9875</pos>
            <iconColor>cccccc</iconColor>
            <textColor>cccccc</textColor>
            <backgroundColor>181818</backgroundColor>
            <backgroundHorizontalPadding>0.01 0.01</backgroundHorizontalPadding>
            <backgroundVerticalPadding>0.015 0.02</backgroundVerticalPadding>
            <backgroundCornerRadius>0.005</backgroundCornerRadius>
            <entryRelativeScale>0.9</entryRelativeScale>
        </helpsystem>
        <!-- End: menu styling resets -->

        <image name="background">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <path>${spacerImage}</path>
            <tile>true</tile>
            <zIndex>0</zIndex>
        </image>

        <clock name="clock">
            <origin>0 0</origin>
            <fontPath>${fontLight}</fontPath>
            <color>${statusColor}</color>
            <backgroundColor>${statusBackgroundColor}</backgroundColor>
            <backgroundCornerRadius>0.01</backgroundCornerRadius>
        </clock>

        <systemstatus name="system-status">
            <origin>1 0.5</origin>
            <textRelativeScale>0.7</textRelativeScale>
            <fontPath>${fontLight}</fontPath>
            <customIcon icon="icon_bluetooth">./_inc/images/icon-bluetooth.svg</customIcon>
            <customIcon icon="icon_wifi">./_inc/images/icon-wifi.svg</customIcon>
            <customIcon icon="icon_cellular">./_inc/images/icon-cellular.svg</customIcon>
            <customIcon icon="icon_battery_charging">./_inc/images/icon-battery-charging.svg</customIcon>
            <customIcon icon="icon_battery_full">./_inc/images/icon-battery-full.svg</customIcon>
            <customIcon icon="icon_battery_high">./_inc/images/icon-battery-high.svg</customIcon>
            <customIcon icon="icon_battery_medium">./_inc/images/icon-battery-medium.svg</customIcon>
            <customIcon icon="icon_battery_low">./_inc/images/icon-battery-low.svg</customIcon>
            <color>${statusColor}</color>
            <backgroundColor>${statusBackgroundColor}</backgroundColor>
            <backgroundCornerRadius>0.01</backgroundCornerRadius>
        </systemstatus>

        <helpsystem name="help-system-view,help-gamelist-view">
            <scope>view</scope>
            <iconColor>${helpIconColor}</iconColor>
            <textColor>${helpTextColor}</textColor>
            <backgroundColor>${helpBackgroundColor}</backgroundColor>
            <backgroundCornerRadius>0.01</backgroundCornerRadius>
            <entryRelativeScale>0.7</entryRelativeScale>
        </helpsystem>

    </view>

    <!-- /// System View /// -->
    <view name="system">

        <image name="background">
            <color>${systemBackgroundColor}</color>
        </image>

        <carousel name="system-carousel">
            <origin>0 0</origin>
            <pos>0 0</pos>
            <size>1 1</size>
            <color>00000000</color>
            <textColor>00000000</textColor>
            <itemTransitions>animate</itemTransitions>
            <itemVerticalAlignment>center</itemVerticalAlignment>
            <fastScrolling>true</fastScrolling>
            <defaultImage>${artworkSource}/_default.png</defaultImage>
            <staticImage>${artworkSource}/${system.theme}.png</staticImage>
            <imageColor>${systemArtColor}</imageColor>
            <imageSelectedColor>${systemArtColor}</imageSelectedColor>
            <imageSaturation>${systemArtSaturation}</imageSaturation>
            <itemScale>1</itemScale>
            <itemSize>1 1</itemSize>
            <zIndex>1</zIndex>
        </carousel>

        <image name="system-logo">
            <origin>0.5 0.5</origin>
            <pos>${systemViewLogoPos}</pos>
            <maxSize>0.5 0.3</maxSize>
            <default>./_inc/systems/logos/${system.theme}.svg</default>
            <path>${logoSource}/${system.theme}.svg</path>
            <color>${systemLogoColor}</color>
            <zIndex>3</zIndex>
        </image>

    </view>

    <!-- /// Gamelist View - Global /// -->
    <view name="gamelist">

        <clock name="clock">
            <scope>none</scope>
        </clock>

        <!-- System logo shown large and dim in top-left, like Zune's "HLD" watermark -->
        <image name="logo">
            <origin>0 0</origin>
            <default>./_inc/systems/logos/${system.theme}.svg</default>
            <path>${logoSource}/${system.theme}.svg</path>
            <color>${gamelistListLogoColor}</color>
            <zIndex>5</zIndex>
        </image>

        <text name="custom-collection-name">
            <fontPath>${fontLogo}</fontPath>
        </text>

    </view>

    <!-- /// Gamelist View - All List Variants (shared base) /// -->
    <variant name="
        gamelist-list-basic,
        gamelist-list-basic-nh,
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">

            <image name="background">
                <color>${gamelistListBackgroundColor}</color>
            </image>

            <badges name="badges">
                <lines>1</lines>
                <itemsPerLine>5</itemsPerLine>
                <itemMargin>0 0</itemMargin>
                <slots>folder,favorite,completed,collection,altemulator</slots>
                <customBadgeIcon badge="folder">./_inc/images/badge-folder.svg</customBadgeIcon>
                <customBadgeIcon badge="favorite">./_inc/images/badge-favorite.svg</customBadgeIcon>
                <customBadgeIcon badge="completed">./_inc/images/badge-completed.svg</customBadgeIcon>
                <customBadgeIcon badge="collection">./_inc/images/badge-collection.svg</customBadgeIcon>
                <customBadgeIcon badge="altemulator">./_inc/images/badge-altemulator.svg</customBadgeIcon>
                <controllerSize>0.8</controllerSize>
                <folderLinkSize>0.8</folderLinkSize>
            </badges>

            <badges name="badges">
                <origin>0 0.5</origin>
                <horizontalAlignment>left</horizontalAlignment>
                <direction>row</direction>
            </badges>

            <!-- Left panel background (the dark sidebar behind the list) -->
            <image name="gamelist-background">
                <origin>0 0</origin>
                <pos>0 0</pos>
                <path>${spacerImage}</path>
                <tile>true</tile>
                <color>${gamelistListTextlistBackgroundColor}</color>
                <zIndex>4</zIndex>
            </image>

            <image name="logo">
                <color>${gamelistListLogoColor}</color>
            </image>

            <textlist name="gamelist-list">
                <origin>0 0</origin>
                <horizontalAlignment>left</horizontalAlignment>
                <fontPath>${fontRegular}</fontPath>
                <systemNameSuffix>false</systemNameSuffix>
                <selectorColor>00000000</selectorColor>
                <selectedColor>${gamelistListTextlistSelectedColor}</selectedColor>
                <primaryColor>${gamelistListTextlistUnselectedColor}</primaryColor>
                <secondaryColor>${gamelistListTextlistUnselectedColor}</secondaryColor>
                <selectedBackgroundColor>${gamelistListTextlistSelectedBackgroundColor}</selectedBackgroundColor>
                <selectedBackgroundCornerRadius>0.005</selectedBackgroundCornerRadius>
                <zIndex>5</zIndex>
            </textlist>

        </view>
    </variant>

    <!-- Basic variant: full-width centered list -->
    <variant name="
        gamelist-list-basic,
        gamelist-list-basic-nh
    ">
        <view name="gamelist">
            <image name="gamelist-background">
                <size>1 1</size>
            </image>
            <textlist name="gamelist-list">
                <horizontalAlignment>center</horizontalAlignment>
            </textlist>
        </view>
    </variant>

    <!-- Video fallback settings for all art variants -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <delay>3</delay>
                <iterationCount>1</iterationCount>
                <onIterationsDone>image</onIterationsDone>
                <interpolation>nearest</interpolation>
                <pillarboxes>false</pillarboxes>
            </video>
        </view>
    </variant>

    <!-- /// ZUNE-STYLE METADATA BLOCK                                          /// -->
    <!-- Mapped to the Zune track listing:                                          -->
    <!--   description  → not shown (no equivalent in music UI)                    -->
    <!--   developer    → shown small, like "artist name" subtitle                 -->
    <!--   genre        → shown tiny/dim, like track names in listing              -->
    <!--   releasedate  → shown tiny/dim alongside genre                           -->
    <!--   players      → shown tiny/dim alongside other track-style metadata      -->
    <!--   rating       → hidden (no Zune equivalent)                              -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh
    ">
        <view name="gamelist">

            <!-- Description: hidden - not part of Zune music-list aesthetic -->
            <text name="description">
                <visible>false</visible>
            </text>

            <!-- Rating: hidden -->
            <rating name="rating">
                <visible>false</visible>
            </rating>

            <!-- Developer label: shown as "artist" subtitle below game name  -->
            <!-- Positioned by aspect ratio files                              -->
            <text name="developer">
                <origin>0 0</origin>
                <metadata>developer</metadata>
                <defaultValue>Unknown Developer</defaultValue>
                <fontPath>${fontRegular}</fontPath>
                <letterCase>uppercase</letterCase>
                <lineSpacing>1</lineSpacing>
                <color>${gamelistListMetadataColor}</color>
                <container>false</container>
                <visible>true</visible>
            </text>

            <!-- Genre: shown tiny and dim, like a track name in Zune listing -->
            <image name="genre-icon">
                <visible>false</visible><!-- hide icon, text only like Zune -->
            </image>
            <text name="genre">
                <origin>0 0</origin>
                <metadata>genre</metadata>
                <defaultValue></defaultValue>
                <fontPath>${fontLight}</fontPath>
                <letterCase>uppercase</letterCase>
                <lineSpacing>1</lineSpacing>
                <color>${gamelistListMetadataIconColor}</color>
                <container>true</container>
                <containerType>horizontal</containerType>
                <visible>true</visible>
            </text>

            <!-- Release date: tiny, dim, inline with genre cluster -->
            <image name="releasedate-icon">
                <visible>false</visible>
            </image>
            <datetime name="releasedate">
                <origin>0 0</origin>
                <metadata>releasedate</metadata>
                <defaultValue></defaultValue>
                <fontPath>${fontLight}</fontPath>
                <lineSpacing>1</lineSpacing>
                <color>${gamelistListMetadataIconColor}</color>
                <visible>true</visible>
            </datetime>

            <!-- Players: tiny, dim -->
            <image name="players-icon">
                <visible>false</visible>
            </image>
            <text name="players">
                <origin>0 0</origin>
                <metadata>players</metadata>
                <defaultValue></defaultValue>
                <fontPath>${fontLight}</fontPath>
                <lineSpacing>1</lineSpacing>
                <color>${gamelistListMetadataIconColor}</color>
                <visible>true</visible>
            </text>

            <!-- Publisher, last played, play time: hidden to keep it clean -->
            <image name="publisher-icon">
                <visible>false</visible>
            </image>
            <text name="publisher">
                <visible>false</visible>
            </text>
            <image name="last-played-icon">
                <visible>false</visible>
            </image>
            <datetime name="last-played">
                <visible>false</visible>
            </datetime>
            <image name="play-time-icon">
                <visible>false</visible>
            </image>
            <text name="play-time">
                <visible>false</visible>
            </text>

        </view>
    </variant>

    <!-- /// Gamelist View - Metadata & Miximage: square-crop art /// -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <imageType>miximage</imageType>
            </video>
        </view>
    </variant>

    <!-- /// Gamelist View - Metadata & Boxart (PRIMARY ZUNE VARIANT)          /// -->
    <!-- Square-cropped screenshot used as the "album art" square on the left   /// -->
    <variant name="
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <imageType>screenshot,cover</imageType>
                <!-- Force square crop - key to matching Zune album art squares -->
                <imageCornerRadius>0</imageCornerRadius>
            </video>
        </view>
    </variant>

    <!-- /// Gamelist View - Metadata & Screenshot + Marquee /// -->
    <variant name="
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <imageType>screenshot</imageType>
                <zIndex>1</zIndex>
            </video>
            <image name="marquee">
                <origin>1 1</origin>
                <imageType>marquee</imageType>
            </image>
        </view>
    </variant>

    <!-- /// Gamelist View - Metadata & Screenshot + Boxart /// -->
    <variant name="
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <imageType>screenshot</imageType>
                <zIndex>1</zIndex>
            </video>
            <image name="cover">
                <origin>1 1</origin>
                <imageType>cover</imageType>
                <cornerRadius>0.005</cornerRadius>
            </image>
        </view>
    </variant>

    <!-- /// Gamelist View - Boxart only /// -->
    <variant name="
        gamelist-list-cover,
        gamelist-list-cover-nh
    ">
        <view name="gamelist">
            <image name="background">
                <color>${gamelistListTextlistBackgroundColor}</color>
            </image>
            <video name="game-art">
                <origin>0.5 0.5</origin>
                <imageCornerRadius>0</imageCornerRadius>
                <imageType>cover</imageType>
                <zIndex>1</zIndex>
            </video>
        </view>
    </variant>

    <!-- /// Gamelist View - Screenshot + Marquee /// -->
    <variant name="
        gamelist-list-screenshot-marquee,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0.5 0.5</origin>
                <imageType>screenshot</imageType>
                <zIndex>1</zIndex>
            </video>
            <image name="marquee">
                <origin>0.5 0.5</origin>
                <imageType>marquee</imageType>
            </image>
        </view>
    </variant>

    <!-- /// Gamelist View - Grid Variants /// -->
    <variant name="
        gamelist-grid-cover,
        gamelist-grid-cover-nh
    ">
        <include>./_inc/systems/_coversize/${systemCoverSize}.xml</include>
        <view name="gamelist">
            <grid name="gamelist-grid">
                <imageType>cover,screenshot</imageType>
            </grid>
        </view>
    </variant>

    <variant name="
        gamelist-grid-cover-steamgriddb,
        gamelist-grid-cover-steamgriddb-nh
    ">
        <include>./_inc/systems/_coversize/2-3.xml</include>
        <view name="gamelist">
            <grid name="gamelist-grid">
                <imageType>cover</imageType>
            </grid>
        </view>
    </variant>

    <variant name="
        gamelist-grid-screenshot,
        gamelist-grid-screenshot-nh
    ">
        <include>./_inc/systems/_coversize/1-1.xml</include>
        <view name="gamelist">
            <grid name="gamelist-grid">
                <imageType>screenshot</imageType>
                <imageFit>cover</imageFit>
            </grid>
        </view>
    </variant>

    <variant name="
        gamelist-grid-cover,
        gamelist-grid-cover-nh,
        gamelist-grid-cover-steamgriddb,
        gamelist-grid-cover-steamgriddb-nh,
        gamelist-grid-screenshot,
        gamelist-grid-screenshot-nh
    ">
        <view name="gamelist">
            <image name="background">
                <color>000000</color>
            </image>
            <image name="logo">
                <origin>0 0.5</origin>
                <color>${gamelistListLogoColor}</color>
            </image>
            <text name="game-name">
                <origin>0.5 0.5</origin>
                <metadata>name</metadata>
                <fontPath>${fontRegular}</fontPath>
                <systemNameSuffix>false</systemNameSuffix>
                <lineSpacing>1</lineSpacing>
                <fontSize>0.0333333</fontSize>
                <color>${gamelistListMetadataColor}</color>
                <horizontalAlignment>center</horizontalAlignment>
            </text>
            <image name="menu-bar">
                <origin>0 0</origin>
                <pos>0 0</pos>
                <size>1 0.116666666666667</size>
                <path>${spacerImage}</path>
                <tile>true</tile>
                <color>${gamelistListTextlistBackgroundColor}</color>
                <zIndex>1</zIndex>
            </image>
            <image name="menu-bar-border">
                <origin>0 0</origin>
                <pos>0 0.116666666666667</pos>
                <size>1 0.004166666666667</size>
                <path>${spacerImage}</path>
                <tile>true</tile>
                <color>000000</color>
                <zIndex>2</zIndex>
            </image>
            <grid name="gamelist-grid">
                <origin>0 0</origin>
                <pos>0 0.116666666666667</pos>
                <size>1 0.883333333333333</size>
                <itemScale>1.2</itemScale>
                <scaleInwards>true</scaleInwards>
                <itemSpacing>0.002344665885111 0.004166666666667</itemSpacing>
                <unfocusedItemOpacity>0.5</unfocusedItemOpacity>
                <unfocusedItemDimming>1</unfocusedItemDimming>
                <unfocusedItemSaturation>1</unfocusedItemSaturation>
                <fractionalRows>true</fractionalRows>
                <textColor>ffffff</textColor>
                <textBackgroundColor>222222</textBackgroundColor>
                <backgroundColor>000000</backgroundColor>
                <fontPath>${fontRegular}</fontPath>
                <fontSize>0.03</fontSize>
                <textRelativeScale>0.99</textRelativeScale>
                <imageRelativeScale>1</imageRelativeScale>
                <imageCornerRadius>0.004</imageCornerRadius>
                <backgroundCornerRadius>0.004</backgroundCornerRadius>
                <textBackgroundCornerRadius>0.004</textBackgroundCornerRadius>
                <zIndex>2</zIndex>
            </grid>
        </view>
    </variant>

    <!-- /// Aspect Ratios /// -->
    <aspectRatio name="32:9">  <include>./aspect-ratio-32-9.xml</include>  </aspectRatio>
    <aspectRatio name="21:9">  <include>./aspect-ratio-21-9.xml</include>  </aspectRatio>
    <aspectRatio name="20:9">  <include>./aspect-ratio-20-9.xml</include>  </aspectRatio>
    <aspectRatio name="19.5:9"><include>./aspect-ratio-19_5-9.xml</include></aspectRatio>
    <aspectRatio name="16:9">  <include>./aspect-ratio-16-9.xml</include>  </aspectRatio>
    <aspectRatio name="16:10"> <include>./aspect-ratio-16-10.xml</include> </aspectRatio>
    <aspectRatio name="3:2">   <include>./aspect-ratio-3-2.xml</include>   </aspectRatio>
    <aspectRatio name="4:3">   <include>./aspect-ratio-4-3.xml</include>   </aspectRatio>
    <aspectRatio name="5:4">   <include>./aspect-ratio-5-4.xml</include>   </aspectRatio>
    <aspectRatio name="8:7">   <include>./aspect-ratio-8-7.xml</include>   </aspectRatio>
    <aspectRatio name="1:1">   <include>./aspect-ratio-1-1.xml</include>   </aspectRatio>
    <aspectRatio name="5:3_vertical"><include>./aspect-ratio-5-3-vert.xml</include></aspectRatio>

    <!-- /// Sounds /// -->
    <view name="all">
        <sound name="systembrowse">  <path>./_inc/sounds/systembrowse.wav</path>  </sound>
        <sound name="quicksysselect"><path>./_inc/sounds/quicksysselect.wav</path></sound>
        <sound name="select">        <path>./_inc/sounds/select.wav</path>        </sound>
        <sound name="back">          <path>./_inc/sounds/back.wav</path>          </sound>
        <sound name="scroll">        <path>./_inc/sounds/scroll.wav</path>        </sound>
        <sound name="favorite">      <path>./_inc/sounds/favorite.wav</path>      </sound>
        <sound name="launch">        <path>./_inc/sounds/launch.wav</path>        </sound>
    </view>

</theme>
