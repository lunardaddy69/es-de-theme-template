<!-- 4:3 aspect ratio based on 640x480 -->
<!-- ZUNE HD LAYOUT (4:3 scaled):                             -->
<!--   Left panel:  0 → 240px  (37.5%) - game list           -->
<!--   Right panel: 240 → 640px (62.5%) - art + metadata     -->
<!--   Square art:  240,60 → 360,180  (120×120px)            -->
<theme>

    <!-- /// All Views /// -->
    <view name="system,gamelist">
        <clock name="clock">
            <pos>0.0359375 0.04791667</pos><!-- 23 23 -->
            <fontSize>${clockFontSize}</fontSize>
            <backgroundHorizontalPadding>0.0109375 0.0109375</backgroundHorizontalPadding><!-- 7 -->
            <backgroundVerticalPadding>0.01666667 0.01666667</backgroundVerticalPadding><!-- 8 -->
        </clock>
        <systemstatus name="system-status">
            <pos>0.96875 0.0625</pos><!-- 620 30 -->
            <height>${systemStatusHeight}</height>
            <backgroundHorizontalPadding>0.0109375 0.0109375</backgroundHorizontalPadding><!-- 7 -->
            <backgroundVerticalPadding>0.01041667 0.01041667</backgroundVerticalPadding><!-- 5 -->
            <entries>all</entries>
        </systemstatus>
    </view>

    <variant name="
        gamelist-list-basic,
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-cover,
        gamelist-list-screenshot-marquee
    ">
        <view name="system,gamelist">
            <helpsystem name="help-system-view,help-gamelist-view">
                <fontSize>${helpsystemFontSize}</fontSize>
                <backgroundHorizontalPadding>0.015625 0.015625</backgroundHorizontalPadding><!-- 10 -->
                <backgroundVerticalPadding>0.01458333 0.01458333</backgroundVerticalPadding><!-- 7 -->
                <entrySpacing>0.01875</entrySpacing><!-- 12 -->
                <iconTextSpacing>0.0078125</iconTextSpacing><!-- 5 -->
            </helpsystem>
        </view>
        <view name="system">
            <helpsystem name="help-system-view">
                <origin>0.5 1</origin>
                <pos>0.5 0.9375</pos>
                <entries>${helpSystemViewEntries}</entries>
            </helpsystem>
            <helpsystem name="help-gamelist-view">
                <scope>none</scope>
            </helpsystem>
        </view>
        <view name="gamelist">
            <helpsystem name="help-system-view">
                <scope>none</scope>
            </helpsystem>
            <helpsystem name="help-gamelist-view">
                <origin>0 1</origin>
                <pos>0.0546875 0.9375</pos><!-- 35 450 -->
                <entries>${helpGamelistViewEntries}</entries>
            </helpsystem>
        </view>
    </variant>

    <variant name="gamelist-list-basic">
        <view name="gamelist">
            <helpsystem name="help-gamelist-view">
                <origin>0.5 1</origin>
                <pos>0.5 0.9375</pos>
            </helpsystem>
        </view>
    </variant>

    <variant name="
        gamelist-list-basic-nh,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee-nh,
        gamelist-grid-cover-nh,
        gamelist-grid-cover-steamgriddb-nh,
        gamelist-grid-screenshot-nh
    ">
        <view name="system,gamelist">
            <helpsystem name="help-system-view,help-gamelist-view">
                <origin>0 0</origin>
                <pos>1 1</pos>
            </helpsystem>
        </view>
    </variant>

    <variant name="
        gamelist-grid-cover,
        gamelist-grid-cover-steamgriddb,
        gamelist-grid-screenshot
    ">
        <view name="system,gamelist">
            <helpsystem name="help-system-view,help-gamelist-view">
                <fontSize>${helpsystemFontSize}</fontSize>
                <backgroundHorizontalPadding>0.015625 0.015625</backgroundHorizontalPadding>
                <backgroundVerticalPadding>0.01458333 0.01458333</backgroundVerticalPadding>
                <entrySpacing>0.01875</entrySpacing>
                <iconTextSpacing>0.0078125</iconTextSpacing>
            </helpsystem>
        </view>
        <view name="system">
            <helpsystem name="help-system-view">
                <origin>0.5 1</origin>
                <pos>0.5 0.9375</pos>
                <entries>${helpSystemViewEntries}</entries>
            </helpsystem>
            <helpsystem name="help-gamelist-view">
                <scope>none</scope>
            </helpsystem>
        </view>
        <view name="gamelist">
            <helpsystem name="help-system-view">
                <scope>none</scope>
            </helpsystem>
            <helpsystem name="help-gamelist-view">
                <origin>0.5 1</origin>
                <pos>0.5 0.9375</pos>
                <entries>${helpSystemViewEntries}</entries>
            </helpsystem>
        </view>
    </variant>

    <fontSize name="small">
        <variables>
            <clockFontSize>0.025</clockFontSize>
            <systemStatusHeight>0.0375</systemStatusHeight>
            <helpsystemFontSize>0.04166667</helpsystemFontSize>
            <helpSystemViewEntries>start,back,a,x,left/right</helpSystemViewEntries>
            <helpGamelistViewEntries>back,start,a</helpGamelistViewEntries>
        </variables>
    </fontSize>
    <fontSize name="medium">
        <variables>
            <clockFontSize>0.02916667</clockFontSize>
            <systemStatusHeight>0.04166667</systemStatusHeight>
            <helpsystemFontSize>0.04583333</helpsystemFontSize>
            <helpSystemViewEntries>start,back,a,x,left/right</helpSystemViewEntries>
            <helpGamelistViewEntries>back,start,a</helpGamelistViewEntries>
        </variables>
    </fontSize>
    <fontSize name="large">
        <variables>
            <clockFontSize>0.03333333</clockFontSize>
            <systemStatusHeight>0.04583333</systemStatusHeight>
            <helpsystemFontSize>0.05</helpsystemFontSize>
            <helpSystemViewEntries>start,back,a,x,left/right</helpSystemViewEntries>
            <helpGamelistViewEntries>back,a</helpGamelistViewEntries>
        </variables>
    </fontSize>
    <fontSize name="x-large">
        <variables>
            <clockFontSize>0.05</clockFontSize>
            <systemStatusHeight>0.0625</systemStatusHeight>
            <helpsystemFontSize>0.07083333</helpsystemFontSize>
            <helpSystemViewEntries>start,back,a,left/right</helpSystemViewEntries>
            <helpGamelistViewEntries>back,a</helpGamelistViewEntries>
        </variables>
    </fontSize>

    <!-- /// System View /// -->
    <view name="system">
        <carousel name="system-carousel">
            <maxItemCount>4.15</maxItemCount>
        </carousel>
        <image name="system-logo">
            <maxSize>0.65 0.35</maxSize>
        </image>
    </view>

    <!-- /// All list variants: shared logo + textlist position /// -->
    <variant name="
        gamelist-list-basic,
        gamelist-list-basic-nh,
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <image name="logo">
                <origin>0 0</origin>
                <pos>0.02 0.02</pos>
                <maxSize>0.359375 0.14583333</maxSize><!-- 230 70 -->
            </image>
            <textlist name="gamelist-list">
                <pos>0.0546875 0.20833333</pos><!-- 35 100 -->
                <fontSize>${gamelistFontSize}</fontSize>
                <selectedBackgroundMargins>${gamelistSelectedBackgroundMargins}</selectedBackgroundMargins>
            </textlist>
        </view>
        <fontSize name="small">
            <variables>
                <gamelistFontSize>0.03333333</gamelistFontSize>
                <gamelistSelectedBackgroundMargins>0.0109375 0.0109375</gamelistSelectedBackgroundMargins>
            </variables>
        </fontSize>
        <fontSize name="medium">
            <variables>
                <gamelistFontSize>0.0375</gamelistFontSize>
                <gamelistSelectedBackgroundMargins>0.0125 0.0125</gamelistSelectedBackgroundMargins>
            </variables>
        </fontSize>
        <fontSize name="large">
            <variables>
                <gamelistFontSize>0.04166667</gamelistFontSize>
                <gamelistSelectedBackgroundMargins>0.0125 0.0125</gamelistSelectedBackgroundMargins>
            </variables>
        </fontSize>
        <fontSize name="x-large">
            <variables>
                <gamelistFontSize>0.05833333</gamelistFontSize>
                <gamelistSelectedBackgroundMargins>0.0125 0.0125</gamelistSelectedBackgroundMargins>
            </variables>
        </fontSize>
    </variant>

    <variant name="
        gamelist-list-basic,
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-cover,
        gamelist-list-screenshot-marquee
    ">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <lineSpacing>${gamelistLineSpacing}</lineSpacing>
            </textlist>
        </view>
        <fontSize name="small">   <variables><gamelistLineSpacing>1.94444444</gamelistLineSpacing></variables></fontSize>
        <fontSize name="medium">  <variables><gamelistLineSpacing>1.94444444</gamelistLineSpacing></variables></fontSize>
        <fontSize name="large">   <variables><gamelistLineSpacing>1.98051948</gamelistLineSpacing></variables></fontSize>
        <fontSize name="x-large"> <variables><gamelistLineSpacing>2</gamelistLineSpacing></variables></fontSize>
    </variant>

    <variant name="
        gamelist-list-basic-nh,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <lineSpacing>${gamelistLineSpacing}</lineSpacing>
            </textlist>
        </view>
        <fontSize name="small">   <variables><gamelistLineSpacing>1.90340909</gamelistLineSpacing></variables></fontSize>
        <fontSize name="medium">  <variables><gamelistLineSpacing>1.86111111</gamelistLineSpacing></variables></fontSize>
        <fontSize name="large">   <variables><gamelistLineSpacing>1.86111111</gamelistLineSpacing></variables></fontSize>
        <fontSize name="x-large"> <variables><gamelistLineSpacing>1.70918367</gamelistLineSpacing></variables></fontSize>
    </variant>

    <!-- Basic variant -->
    <variant name="gamelist-list-basic, gamelist-list-basic-nh">
        <view name="gamelist">
            <image name="logo">
                <pos>0.5 0.13020833</pos>
            </image>
        </view>
    </variant>
    <variant name="gamelist-list-basic">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <size>0.890625 0.57083333</size><!-- 570 274 -->
            </textlist>
        </view>
    </variant>
    <variant name="gamelist-list-basic-nh">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <size>0.890625 0.69791667</size><!-- 570 335 -->
            </textlist>
        </view>
    </variant>

    <!-- Left panel + logo for all metadata/art variants -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <image name="gamelist-background">
                <size>0.375 1</size><!-- 240 480 -->
            </image>
            <image name="logo">
                <pos>0.025 0.02083333</pos><!-- 16 10 -->
            </image>
        </view>
    </variant>

    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-cover,
        gamelist-list-screenshot-marquee
    ">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <size>0.3125 0.6875</size><!-- 200 330 -->
            </textlist>
        </view>
    </variant>
    <variant name="
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover-nh,
        gamelist-list-cover-nh,
        gamelist-list-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <textlist name="gamelist-list">
                <size>0.3125 0.8125</size><!-- 200 390 -->
            </textlist>
        </view>
    </variant>

    <!-- Zune metadata positions (4:3 scaled) -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh,
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh,
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh,
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh
    ">
        <view name="gamelist">

            <!-- Developer (artist subtitle) -->
            <text name="developer">
                <pos>0.578125 0.37500000</pos><!-- 370 180 -->
                <size>0.390625 0</size><!-- 250 auto -->
                <fontSize>${gamelistDeveloperFontSize}</fontSize>
                <letterCase>uppercase</letterCase>
            </text>

            <!-- Genre - tiny metadata line 1 -->
            <text name="genre">
                <pos>0.578125 0.47916667</pos><!-- 370 230 -->
                <size>0.390625 0</size>
                <fontSize>${gamelistTinyFontSize}</fontSize>
                <letterCase>uppercase</letterCase>
            </text>

            <!-- Release year - tiny metadata line 2 -->
            <datetime name="releasedate">
                <pos>0.578125 0.54166667</pos><!-- 370 260 -->
                <size>0.390625 0</size>
                <fontSize>${gamelistTinyFontSize}</fontSize>
                <format>%Y</format>
            </datetime>

            <!-- Players - tiny metadata line 3 -->
            <text name="players">
                <pos>0.578125 0.60416667</pos><!-- 370 290 -->
                <size>0.390625 0</size>
                <fontSize>${gamelistTinyFontSize}</fontSize>
            </text>

        </view>

        <fontSize name="small">
            <variables>
                <gamelistDeveloperFontSize>0.03333333</gamelistDeveloperFontSize>
                <gamelistTinyFontSize>0.02500000</gamelistTinyFontSize>
                <gamelistDateFormat>%Y-%m-%d</gamelistDateFormat>
            </variables>
        </fontSize>
        <fontSize name="medium">
            <variables>
                <gamelistDeveloperFontSize>0.03750000</gamelistDeveloperFontSize>
                <gamelistTinyFontSize>0.02916667</gamelistTinyFontSize>
                <gamelistDateFormat>%Y-%m-%d</gamelistDateFormat>
            </variables>
        </fontSize>
        <fontSize name="large">
            <variables>
                <gamelistDeveloperFontSize>0.04166667</gamelistDeveloperFontSize>
                <gamelistTinyFontSize>0.03125000</gamelistTinyFontSize>
                <gamelistDateFormat>%Y</gamelistDateFormat>
            </variables>
        </fontSize>
        <fontSize name="x-large">
            <variables>
                <gamelistDeveloperFontSize>0.05000000</gamelistDeveloperFontSize>
                <gamelistTinyFontSize>0.03333333</gamelistTinyFontSize>
                <gamelistDateFormat>%Y</gamelistDateFormat>
            </variables>
        </fontSize>
    </variant>

    <!-- Square art - 120×120px centered in right panel -->
    <variant name="
        gamelist-list-metadata-miximage,
        gamelist-list-metadata-miximage-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <pos>0.375 0.5</pos><!-- 240 240 -->
                <cropSize>0.1875 0.25</cropSize><!-- 120x120 - SQUARE -->
                <imageMaxSize>0.1875 0.25</imageMaxSize>
            </video>
        </view>
    </variant>

    <variant name="
        gamelist-list-metadata-cover,
        gamelist-list-metadata-cover-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <pos>0.375 0.5</pos><!-- 240 240 -->
                <cropSize>0.1875 0.25</cropSize><!-- 120x120 - SQUARE -->
                <imageMaxSize>0.1875 0.25</imageMaxSize>
            </video>
            <badges name="badges">
                <pos>0.375 0.70833333</pos><!-- 240 340 -->
                <size>0.1875 0.05</size>
            </badges>
        </view>
    </variant>

    <variant name="
        gamelist-list-metadata-screenshot-marquee,
        gamelist-list-metadata-screenshot-marquee-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <pos>0.375 0.5</pos>
                <cropSize>0.1875 0.25</cropSize><!-- 120x120 - SQUARE -->
            </video>
            <image name="marquee">
                <origin>0 0</origin>
                <pos>0.375 0.10416667</pos>
                <maxSize>0.1875 0.08333333</maxSize>
            </image>
            <badges name="badges">
                <pos>0.375 0.70833333</pos>
                <size>0.1875 0.05</size>
            </badges>
        </view>
    </variant>

    <variant name="
        gamelist-list-metadata-screenshot-cover,
        gamelist-list-metadata-screenshot-cover-nh
    ">
        <view name="gamelist">
            <video name="game-art">
                <origin>0 0.5</origin>
                <pos>0.375 0.5</pos>
                <cropSize>0.1875 0.25</cropSize><!-- 120x120 - SQUARE -->
            </video>
            <image name="cover">
                <origin>0 0</origin>
                <pos>0.375 0.10416667</pos>
                <maxSize>0.09375 0.16666667</maxSize>
            </image>
            <badges name="badges">
                <pos>0.375 0.70833333</pos>
                <size>0.1875 0.05</size>
            </badges>
        </view>
    </variant>

    <variant name="gamelist-list-cover, gamelist-list-cover-nh">
        <view name="gamelist">
            <video name="game-art">
                <pos>0.75 0.5</pos>
                <imageMaxSize>0.40625 0.864583333333333</imageMaxSize>
                <cropSize>0.5 1</cropSize>
            </video>
        </view>
    </variant>

    <variant name="gamelist-list-screenshot-marquee, gamelist-list-screenshot-marquee-nh">
        <view name="gamelist">
            <image name="marquee">
                <pos>0.75 0.5</pos>
                <maxSize>0.359375 0.625</maxSize>
            </image>
            <video name="game-art">
                <pos>0.75 0.5</pos>
                <cropSize>0.5 1</cropSize>
            </video>
        </view>
    </variant>

    <!-- Grid variants -->
    <variant name="
        gamelist-grid-cover,
        gamelist-grid-cover-nh,
        gamelist-grid-cover-steamgriddb,
        gamelist-grid-cover-steamgriddb-nh,
        gamelist-grid-screenshot,
        gamelist-grid-screenshot-nh
    ">
        <view name="gamelist">
            <image name="logo">
                <maxSize>0.203125 0.05</maxSize><!-- 130 22 -->
                <pos>0.028125 0.0625</pos><!-- 18 30 -->
            </image>
            <text name="game-name">
                <pos>0.5 0.062</pos>
                <size>0.4 0</size>
            </text>
        </view>
    </variant>

</theme>
